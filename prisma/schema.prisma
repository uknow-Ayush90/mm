generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  displayName        String
  avatarColor        String              @default("#7c3aed")
  role               Role                @default(USER)
  totalScore         Int                 @default(0)
  memes              Meme[]
  votes              Vote[]
  comments           Comment[]
  deskReviews        DeskReview[]
  deskReviewVotes    DeskReviewVote[]
  deskReviewComments DeskReviewComment[]
  createdAt          DateTime            @default(now())
}

model Meme {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  publicId  String
  upvotes   Int       @default(0)
  downvotes Int       @default(0)
  score     Int       @default(0)
  isRemoved Boolean   @default(false)
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  tags      MemeTag[]
  votes     Vote[]
  comments  Comment[]
  createdAt DateTime  @default(now())
}

model Vote {
  id     String   @id @default(cuid())
  type   VoteType
  user   User     @relation(fields: [userId], references: [id])
  userId String
  meme   Meme     @relation(fields: [memeId], references: [id])
  memeId String

  @@unique([userId, memeId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  meme      Meme     @relation(fields: [memeId], references: [id])
  memeId    String
  createdAt DateTime @default(now())
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  memes MemeTag[]
}

model MemeTag {
  meme   Meme   @relation(fields: [memeId], references: [id], onDelete: Cascade)
  memeId String
  tag    Tag    @relation(fields: [tagId], references: [id])
  tagId  String

  @@id([memeId, tagId])
}

enum Role {
  USER
  ADMIN
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

model DeskReview {
  id        String              @id @default(cuid())
  title     String
  imageUrl  String
  publicId  String
  upvotes   Int                 @default(0)
  downvotes Int                 @default(0)
  score     Int                 @default(0)
  isRemoved Boolean             @default(false)
  author    User                @relation(fields: [authorId], references: [id])
  authorId  String
  tags      DeskReviewTag[]
  votes     DeskReviewVote[]
  comments  DeskReviewComment[]
  createdAt DateTime            @default(now())
}

model DeskReviewVote {
  id           String     @id @default(cuid())
  type         VoteType
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  deskReview   DeskReview @relation(fields: [deskReviewId], references: [id])
  deskReviewId String

  @@unique([userId, deskReviewId])
}

model DeskReviewComment {
  id           String     @id @default(cuid())
  body         String
  author       User       @relation(fields: [authorId], references: [id])
  authorId     String
  deskReview   DeskReview @relation(fields: [deskReviewId], references: [id])
  deskReviewId String
  createdAt    DateTime   @default(now())
}

model DeskTag {
  slug    String          @id
  name    String          @unique
  reviews DeskReviewTag[]
}

model DeskReviewTag {
  deskReview   DeskReview @relation(fields: [deskReviewId], references: [id], onDelete: Cascade)
  deskReviewId String
  tag          DeskTag    @relation(fields: [tagSlug], references: [slug])
  tagSlug      String

  @@id([deskReviewId, tagSlug])
}
